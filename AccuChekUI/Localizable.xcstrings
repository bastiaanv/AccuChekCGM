    "Your sensor is calibrating. To complete the calibration phase, make sure to calibate between %@ and %@" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم معايرة المستشعر الخاص بك. لإكمال مرحلة المعايرة، تأكد من إجراء المعايرة بين %@ و %@"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snímač se kalibruje. Chcete-li dokončit fázi kalibrace, ujistěte se, že jste kalibrovali mezi %@ a %@."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din sensor er ved at blive kalibreret. For at afslutte kalibreringsfasen skal du sørge for at kalibrere mellem %@ og %@."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Sensor wird gerade kalibriert. Um die Kalibrierungsphase abzuschließen, stellen Sie sicher, dass Sie zwischen %@ und %@ kalibrieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sensor is calibrating. To complete the calibration phase, make sure to calibate between %@ and %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su sensor se está calibrando. Para completar la fase de calibración, asegúrese de calibrar entre %@ y %@."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anturi kalibroi. Kalibrointivaiheen loppuunsaattamiseksi varmista, että kalibrointi tapahtuu %@ ja %@ välillä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre capteur est en train de se calibrer. Pour terminer la phase de calibrage, assurez-vous de calibrer entre %@ et %@"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "החיישן שלך מכויל. כדי להשלים את שלב הכיול, הקפד לבצע בין %@ ל- %@"
