    "It might take up to a full minute before the pairing is completed. Make sure to keep the twist cap till the pairing is complete." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد يستغرق الأمر ما يصل إلى دقيقة كاملة قبل اكتمال الاقتران. تأكد من الاحتفاظ بالغطاء الملتوي حتى يكتمل الاقتران."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spárování může trvat až celou minutu. Až do dokončení párování nezapomeňte držet otočný uzávěr."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det kan tage op til et helt minut, før parringen er færdig. Sørg for at beholde skruelåget på, indtil parringen er fuldført."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es kann bis zu einer ganzen Minute dauern, bis die Kopplung abgeschlossen ist. Achten Sie darauf, die Drehkappe aufzubewahren, bis das Pairing abgeschlossen ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It might take up to a full minute before the pairing is completed. Make sure to keep the twist cap till the pairing is complete."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El emparejamiento puede tardar hasta un minuto en completarse. Asegúrate de mantener la tapa giratoria hasta que se complete el emparejamiento."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pariliitoksen muodostaminen voi kestää jopa minuutin. Pidä kierrekorkki kiinni, kunnes pariliitos on valmis."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il peut s'écouler jusqu'à une minute complète avant que l'appairage ne soit terminé. Veillez à conserver le capuchon rotatif jusqu'à ce que l'appairage soit terminé."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ייתכן שיחלוף דקה שלמה עד לסיום ההתאמה. הקפד לשמור על מכסה הטוויסט עד לסיום ההתאמה."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A párosítás befejezése akár egy teljes percig is eltarthat. A párosítás befejezéséig tartsa a csavaros kupakot."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potrebbe essere necessario un minuto intero prima che l'accoppiamento sia completato. Assicurarsi di mantenere il tappo a spirale fino al completamento dell'accoppiamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ペアリングが完了するまで、1分ほどかかる場合があります。ペアリングが完了するまで、必ずツイストキャップをかぶっておいてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "페어링이 완료되기까지 최대 1분 정도 걸릴 수 있습니다. 페어링이 완료될 때까지 트위스트 캡을 보관하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det kan ta opptil ett minutt før paringen er fullført. Sørg for å holde på vrihetten til sammenkoblingen er fullført."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het kan een volle minuut duren voor het koppelen voltooid is. Zorg ervoor dat je de draaidop ingedrukt houdt tot het koppelen voltooid is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zakończenie parowania może potrwać do pełnej minuty. Upewnij się, że trzymasz zakrętkę do momentu zakończenia parowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pode demorar até um minuto antes de o emparelhamento estar concluído. Certifique-se de que mantém a tampa rotativa até o emparelhamento estar concluído."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este posibil să dureze până la un minut până la finalizarea asocierii. Asigurați-vă că mențineți capacul răsucit până la finalizarea asocierii."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сопряжение может занять до минуты. Не снимайте закручивающуюся крышку до завершения сопряжения."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Môže trvať až celú minútu, kým sa párovanie dokončí. Uistite sa, že otočný uzáver zostal až do dokončenia párovania."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parjenje se lahko zaključi šele čez celo minuto. Prepričajte se, da je pokrovček z zasukom zaprt, dokler se seznanjanje ne konča."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det kan ta upp till en hel minut innan parkopplingen är klar. Se till att behålla skruvkorken på tills parkopplingen är klar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eşleştirmenin tamamlanması tam bir dakika kadar sürebilir. Eşleştirme tamamlanana kadar çevirmeli kapağı tuttuğunuzdan emin olun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для завершення сполучення може знадобитися до хвилини. Не знімайте заглушку до завершення сполучення."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Có thể mất đến một phút trước khi quá trình ghép nối hoàn tất. Đảm bảo giữ nắp xoắn cho đến khi quá trình ghép nối hoàn tất."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "配对完成可能需要整整一分钟。在配对完成前，请务必保留扭转盖。"
          }
        }
      }
    },
