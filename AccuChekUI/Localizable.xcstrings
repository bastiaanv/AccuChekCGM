    "Are you sure you want to pair a new Sensor? You cannot reverse this action." : {
      "comment" : "message repair action sheet",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد من أنك تريد إقران مستشعر جديد؟ لا يمكنك عكس هذا الإجراء."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jste si jisti, že chcete spárovat nový snímač? Tuto akci nelze zvrátit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil parre en ny sensor? Du kan ikke fortryde denne handling."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie einen neuen Sensor koppeln wollen? Sie können diesen Vorgang nicht rückgängig machen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to pair a new Sensor? You cannot reverse this action."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea emparejar un nuevo sensor? No puede anular esta acción."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oletko varma, että haluat yhdistää uuden anturin? Tätä toimenpidettä ei voi peruuttaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir appairer un nouveau capteur ? Vous ne pouvez pas annuler cette action."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "האם אתה בטוח שאתה רוצה להתאים חיישן חדש? אינך יכול להפוך פעולה זו."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztos, hogy új érzékelőt szeretne párosítani? Ezt a műveletet nem tudja visszafordítani."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siete sicuri di voler associare un nuovo sensore? Non è possibile annullare questa operazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本当に新しいセンサーをペアリングしますか？この操作を元に戻すことはできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새 센서를 페어링하시겠습니까? 이 작업은 되돌릴 수 없습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil koble til en ny sensor? Du kan ikke reversere denne handlingen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je een nieuwe sensor wilt koppelen? Je kunt deze actie niet ongedaan maken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz sparować nowy czujnik? Nie można cofnąć tej czynności."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem a certeza de que pretende emparelhar um novo sensor? Não é possível reverter esta ação."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sunteți sigur că doriți să asociați un senzor nou? Nu puteți inversa această acțiune."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите сопрячь новый датчик? Это действие нельзя отменить."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ste si istí, že chcete spárovať nový snímač? Túto akciu nemôžete zvrátiť."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ste prepričani, da želite seznaniti nov senzor? Tega dejanja ne morete spremeniti."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Är du säker på att du vill para ihop en ny sensor? Du kan inte ångra den här åtgärden."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeni bir Sensör eşleştirmek istediğinizden emin misiniz? Bu işlemi geri alamazsınız."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви впевнені, що хочете створити пару з новим датчиком? Ви не можете скасувати цю дію."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có chắc chắn muốn ghép nối một cảm biến mới không? Bạn không thể đảo ngược hành động này."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您确定要配对新传感器吗？此操作无法逆转。"
          }
        }
      }
    },
    "Are you sure you want to stop using Accu-Chek CGM?" : {
      "comment" : "Message for CgmManager deletion action sheet",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد من رغبتك في التوقف عن استخدام جهاز أكيو-تشيك لقياس تجلط الدم؟"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jste si jisti, že chcete přestat používat CGM Accu-Chek?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil holde op med at bruge Accu-Chek CGM?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie Accu-Chek CGM nicht mehr verwenden wollen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to stop using Accu-Chek CGM?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea dejar de utilizar Accu-Chek CGM?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haluatko varmasti lopettaa Accu-Chek CGM:n käytön?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir arrêter d'utiliser Accu-Chek CGM ?"
