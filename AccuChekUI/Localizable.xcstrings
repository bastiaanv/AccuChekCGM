        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az érzékelője kalibrálódik. A kalibrálási fázis befejezéséhez győződjön meg róla, hogy a kalibrálás %@ és %@ között történik."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il sensore è in fase di calibrazione. Per completare la fase di calibrazione, assicurarsi di calibrare tra %@ e %@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
