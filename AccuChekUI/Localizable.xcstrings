    "Select your right or left arm to apply the sensor. Make sure to disinfect the chosen area first." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر ذراعك الأيمن أو الأيسر لتطبيق المستشعر. تأكد من تطهير المنطقة المختارة أولاً."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte pravou nebo levou ruku pro použití senzoru. Nezapomeňte vybranou oblast nejprve vydezinfikovat."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vælg din højre eller venstre arm til at sætte sensoren på. Sørg for at desinficere det valgte område først."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie Ihren rechten oder linken Arm, um den Sensor anzubringen. Achten Sie darauf, die gewählte Stelle vorher zu desinfizieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select your right or left arm to apply the sensor. Make sure to disinfect the chosen area first."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seleccione el brazo derecho o izquierdo para aplicar el sensor. Asegúrese de desinfectar primero la zona elegida."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse oikea tai vasen käsivarsi anturin käyttöä varten. Muista desinfioida valittu alue ensin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sélectionnez votre bras droit ou gauche pour appliquer le capteur. Veillez à désinfecter la zone choisie au préalable."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בחר בזרוע ימין או שמאל כדי להחיל את החיישן. הקפד לחטא תחילה את האזור שנבחר."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válassza ki a jobb vagy bal karját az érzékelő felhelyezéséhez. Ügyeljen arra, hogy először fertőtlenítse a kiválasztott területet."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selezionare il braccio destro o sinistro per applicare il sensore. Assicurarsi di disinfettare prima l'area scelta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "右腕か左腕のどちらかを選んでセンサーを装着してください。まず、選択した部位を消毒してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "센서를 부착할 오른팔 또는 왼팔을 선택합니다. 선택한 부위를 먼저 소독해야 합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velg høyre eller venstre arm for å påføre sensoren. Sørg for å desinfisere det valgte området først."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecteer je rechter- of linkerarm om de sensor aan te brengen. Zorg ervoor dat je het gekozen gebied eerst desinfecteert."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz prawe lub lewe ramię, aby zastosować czujnik. Pamiętaj, aby najpierw zdezynfekować wybrany obszar."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecione o seu braço direito ou esquerdo para aplicar o sensor. Não se esqueça de desinfetar primeiro a área escolhida."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selectați brațul drept sau stâng pentru a aplica senzorul. Asigurați-vă că dezinfectați mai întâi zona aleasă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите правую или левую руку для наложения датчика. Не забудьте предварительно продезинфицировать выбранную область."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte pravú alebo ľavú ruku, aby ste použili snímač. Nezabudnite vybranú oblasť najprv vydezinfikovať."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izberite desno ali levo roko za uporabo senzorja. Izbrano območje najprej razkužite."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Välj höger eller vänster arm för att applicera sensorn. Se till att desinficera det valda området först."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensörü uygulamak için sağ veya sol kolunuzu seçin. Önce seçilen bölgeyi dezenfekte ettiğinizden emin olun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виберіть праву або ліву руку для прикладання датчика. Обов'язково продезінфікуйте обрану ділянку."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chọn cánh tay phải hoặc trái của bạn để áp dụng cảm biến. Đảm bảo khử trùng khu vực đã chọn trước."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择右臂或左臂佩戴传感器。确保先对所选区域进行消毒。"
          }
        }
      }
    },
