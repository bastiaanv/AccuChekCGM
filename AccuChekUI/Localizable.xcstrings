    "Slightly flip the pull tab open. If the pull tab has already been opened before use, discard the device and use a new one." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح لسان السحب قليلاً. إذا كان لسان السحب مفتوحًا بالفعل قبل الاستخدام، تخلصي من الجهاز واستخدمي واحدًا جديدًا."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lehce odklopte stahovací jazýček. Pokud již bylo vytahovací očko před použitím otevřeno, zařízení vyhoďte a použijte nové."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vip trækfanen lidt op. Hvis trækfanen allerede er blevet åbnet før brug, skal du kassere enheden og bruge en ny."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klappen Sie die Aufreißlasche leicht auf. Wenn die Zuglasche bereits vor der Verwendung geöffnet wurde, entsorgen Sie das Gerät und verwenden Sie ein neues."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slightly flip the pull tab open. If the pull tab has already been opened before use, discard the device and use a new one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abra ligeramente la lengüeta. Si la lengüeta ya se ha abierto antes del uso, deseche el dispositivo y utilice uno nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Käännä vetokieleke hieman auki. Jos vetokieleke on jo avattu ennen käyttöä, hävitä laite ja käytä uutta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez légèrement la languette. Si la languette a déjà été ouverte avant l'utilisation, jeter le dispositif et en utiliser un nouveau."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הפוך מעט את לשונית המשיכה פתוחה. אם לשונית המשיכה כבר נפתחה לפני השימוש, השלך את המכשיר והשתמש במכשיר חדש."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kissé fordítsa fel a kihúzófüleket. Ha a kihúzófül már használat előtt kinyílt, dobja ki a készüléket, és használjon újat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aprire leggermente la linguetta di estrazione. Se la linguetta è già stata aperta prima dell'uso, gettare il dispositivo e utilizzarne uno nuovo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プルタブを少しめくって開く。使用前にすでにプルタブが開いている場合は、デバイスを破棄し、新しいものを使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당김 탭을 살짝 젖혀서 엽니다. 사용하기 전에 풀 탭을 이미 열었다면 기기를 폐기하고 새 기기를 사용하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vipp trekkfliken litt opp. Hvis trekkfliken allerede har blitt åpnet før bruk, må du kaste enheten og bruke en ny."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klap het treklipje een beetje open. Als het treklipje al geopend is voor gebruik, gooi het apparaat dan weg en gebruik een nieuwe."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lekko odchylić klapkę. Jeśli klapka została otwarta przed użyciem, wyrzuć urządzenie i użyj nowego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abrir ligeiramente a patilha de puxar. Se a patilha de puxar já tiver sido aberta antes da utilização, deitar fora o dispositivo e utilizar um novo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deschideți ușor clapeta de tragere. Dacă fila de tragere a fost deja deschisă înainte de utilizare, aruncați dispozitivul și utilizați unul nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слегка откиньте выдвижной язычок. Если язычок был открыт перед использованием, выбросьте устройство и используйте новое."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ťažítko mierne otvorte. Ak už bol ťaháčik pred použitím otvorený, zariadenie vyhoďte a použite nové."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nekoliko odprite izvlečni jeziček. Če je bil izvlečni jeziček pred uporabo že odprt, napravo zavrzite in uporabite novo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vänd upp dragfliken en aning. Om dragfliken redan har öppnats före användning ska du kassera enheten och använda en ny."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çekme tırnağını hafifçe çevirerek açın. Çekme tırnağı kullanımdan önce açılmışsa, cihazı atın ve yeni bir tane kullanın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Злегка відкиньте висувну панель. Якщо витяжна планка вже була відкрита перед використанням, викиньте пристрій і використовуйте новий."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hơi lật thanh kéo mở ra. Nếu tab kéo đã được mở trước khi sử dụng, hãy loại bỏ thiết bị và sử dụng thiết bị mới."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "轻轻翻开拉环。如果拉片在使用前已经打开，请丢弃设备并使用新的拉片。"
          }
        }
      }
    },
