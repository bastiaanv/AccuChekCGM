            "value" : "Po kliknutí na tlačidlo Pokračovať sa naskenuje zariadenie Accu chek CGM. Uistite sa, že máte pripravený PIN kód na spárovanie s telefónom!"
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
