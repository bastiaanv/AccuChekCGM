    "Please be patience, this can take a full minute" : {
      "comment" : "connecting",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرجى التحلي بالصبر، فقد يستغرق ذلك دقيقة كاملة"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buďte prosím trpěliví, může to trvat celou minutu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vær tålmodig, det kan tage et helt minut."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte haben Sie etwas Geduld, dies kann eine ganze Minute dauern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please be patience, this can take a full minute"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por favor, sea paciente, esto puede tardar un minuto completo"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ole kärsivällinen, tämä voi kestää kokonaisen minuutin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soyez patient, cela peut prendre une minute entière."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אנא היו סבלניים, זה יכול לקחת דקה שלמה"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kérjük, legyen türelemmel, ez egy teljes percig is eltarthat."
          }
        },
        "it" : {
