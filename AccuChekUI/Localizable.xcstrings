    "Trend Mode" : {

    },
    "Turn the twist cap to open the sterile barrier. You will feel a slight resistance and hear a cracking sound. Pull the twist cap from the applicator." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أدر الغطاء الملتوي لفتح الحاجز المعقم. ستشعر بمقاومة طفيفة وستسمع صوت طقطقة. اسحب الغطاء الملتوي من أداة الاستخدام."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otočením otočného uzávěru otevřete sterilní bariéru. Ucítíte mírný odpor a uslyšíte praskání. Vytáhněte otočný uzávěr z aplikátoru."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drej skruelåget for at åbne den sterile barriere. Du vil mærke en let modstand og høre en knæklyd. Træk drejehætten af applikatoren."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drehen Sie die Drehkappe, um die Sterilbarriere zu öffnen. Sie werden einen leichten Widerstand spüren und ein knackendes Geräusch hören. Ziehen Sie die Drehkappe vom Applikator ab."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turn the twist cap to open the sterile barrier. You will feel a slight resistance and hear a cracking sound. Pull the twist cap from the applicator."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gire el tapón giratorio para abrir la barrera estéril. Sentirá una ligera resistencia y oirá un chasquido. Extraiga el tapón giratorio del aplicador."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Käännä kierrekorkkia avataksesi steriilin esteen. Tunnet lievää vastusta ja kuulet säröäänen. Vedä kierrekorkki applikaattorista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tournez le bouchon pour ouvrir la barrière stérile. Vous sentirez une légère résistance et entendrez un craquement. Retirez le capuchon rotatif de l'applicateur."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "סובב את מכסה הטוויסט כדי לפתוח את המחסום הסטרילי. תרגישו התנגדות קלה ותשמעו צליל פיצוח. משוך את מכסה הטוויסט מהמוליך."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sterilzár kinyitásához fordítsa el a csavaros kupakot. Enyhe ellenállást fog érezni, és egy recsegő hangot fog hallani. Húzza le a csavarható kupakot az applikátorról."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ruotare il tappo per aprire la barriera sterile. Si avvertirà una leggera resistenza e si sentirà un suono di scricchiolio. Estrarre il cappuccio dall'applicatore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ツイストキャップを回して無菌バリアを開ける。わずかな抵抗を感じ、パチンと音がします。ツイストキャップをアプリケーターから引き抜く。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "트위스트 캡을 돌려 멸균 차단막을 엽니다. 약간의 저항이 느껴지고 딱딱한 소리가 들릴 것입니다. 어플리케이터에서 트위스트 캡을 당깁니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vri på vrihetten for å åpne den sterile barrieren. Du vil kjenne en liten motstand og høre en knitrende lyd. Trekk vrihetten av applikatoren."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Draai aan de draaidop om de steriele barrière te openen. Je voelt een lichte weerstand en hoort een krakend geluid. Trek de draaidop van de applicator."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przekręć zakrętkę, aby otworzyć sterylną barierę. Poczujesz lekki opór i usłyszysz trzask. Wyciągnąć nakrętkę z aplikatora."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rodar a tampa rotativa para abrir a barreira estéril. Sentirá uma ligeira resistência e ouvirá um som de estalido. Puxar a tampa rotativa do aplicador."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rotiți capacul răsucit pentru a deschide bariera sterilă. Veți simți o ușoară rezistență și veți auzi un sunet de cracare. Trageți capacul răsucit din aplicator."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поверните закручивающийся колпачок, чтобы открыть стерильный барьер. Вы почувствуете небольшое сопротивление и услышите треск. Вытяните закручивающийся колпачок из аппликатора."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otočením otočného uzáveru otvorte sterilnú bariéru. Pocítite mierny odpor a budete počuť praskanie. Vytiahnite otočný uzáver z aplikátora."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zavrtite pokrovček, da odprete sterilno pregrado. Začutili boste rahel upor in slišali prasketanje. Potegnite navojni pokrovček z aplikatorja."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vrid på skruvkorken för att öppna den sterila barriären. Du kommer att känna ett lätt motstånd och höra ett knakande ljud. Dra bort vridlocket från applikatorn."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Steril bariyeri açmak için çevirmeli kapağı çevirin. Hafif bir direnç hissedecek ve bir çatlama sesi duyacaksınız. Bükümlü kapağı aplikatörden çekin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поверніть ковпачок, щоб відкрити стерильний бар'єр. Ви відчуєте легкий опір і почуєте тріск. Зніміть ковпачок з аплікатора."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Xoay nắp xoắn để mở hàng rào vô trùng. Bạn sẽ cảm thấy một lực cản nhẹ và nghe thấy một âm thanh nứt nẻ. Kẹp nắp xoắn ra khỏi dụng cụ bôi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "旋转扭盖，打开无菌屏障。您会感觉到轻微的阻力，并听到咔哒声。从涂抹器中拔出扭转盖。"
          }
        }
      }
    },
