        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "센서가 보정 중입니다. 보정 단계를 완료하려면 %@에서 %@ 사이에서 보정해야 합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
